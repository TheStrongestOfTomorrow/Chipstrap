    <!-- Optimizations -->
    <string name="opt_title">Optimizations</string>
    <string name="opt_subtitle">Pre-tuned performance settings, applied on launch and reverted on exit.</string>
    <string name="opt_cpu_governor">Force CPU performance governor</string>
    <string name="opt_cpu_governor_desc">Sets scaling_governor to performance while Roblox is foreground (root only).</string>
    <string name="opt_kill_bg">Kill background apps before launch</string>
    <string name="opt_kill_bg_desc">Frees up RAM by stopping non-essential background apps.</string>
    <string name="opt_clear_cache">Clear Roblox cache on launch</string>
    <string name="opt_clear_cache_desc">Wipes Roblox temp/cache before each launch to prevent stutter from stale assets.</string>
    <string name="opt_disable_doze">Disable Doze during gameplay</string>
    <string name="opt_disable_doze_desc">Acquires a partial wakelock to prevent network throttling during long sessions.</string>
    <string name="opt_gpu_tuning">GPU rendering tweak</string>
    <string name="opt_gpu_tuning_desc">Forces hardware-accelerated rendering and disables HWUI overdraw checks.</string>
    <string name="opt_bluetooth_audio">Boost Bluetooth audio buffer</string>
    <string name="opt_bluetooth_audio_desc">Prevents BT audio dropouts during heavy scenes.</string>
    <string name="opt_memory_trim">Memory trim on background</string>
    <string name="opt_memory_trim_desc">Calls trimMemory aggressively when Roblox goes to background.</string>
    <string name="opt_dns">Use low-latency DNS</string>
    <string name="opt_dns_desc">Switches to Cloudflare (1.1.1.1) during gameplay for faster server lookups.</string>

