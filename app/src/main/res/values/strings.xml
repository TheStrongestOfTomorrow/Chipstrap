    <!-- Presets -->
    <string name="preset_ultra_fps">Ultra FPS</string>
    <string name="preset_ultra_fps_desc">Maximum frame rate. Disables shadows, post-FX, lighting bakes; lowest textures; 1x MSAA.</string>
    <string name="preset_balanced">Balanced</string>
    <string name="preset_balanced_desc">Good visuals, smooth framerate. Vulkan, 2x MSAA, medium textures.</string>
    <string name="preset_battery_saver">Battery Saver</string>
    <string name="preset_battery_saver_desc">Caps FPS at 30, disables shadows, lowest textures, reduces draw distance.</string>
    <string name="preset_high_quality">High Quality</string>
    <string name="preset_high_quality_desc">Best visuals. Vulkan, 4x MSAA, high textures, full lighting.</string>
    <string name="preset_low_end">Low-End Device</string>
    <string name="preset_low_end_desc">For devices with &lt;= 3GB RAM. Strips bloat, minimal textures, disables ambient occlusion.</string>
    <string name="preset_competitive">Competitive</string>
    <string name="preset_competitive_desc">Forcibly uncap FPS, lowest input latency, disable bloom/DoF/shadows.</string>
    <string name="preset_apply">Apply preset</string>

