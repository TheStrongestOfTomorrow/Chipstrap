    <!-- About -->
    <string name="about_title">About Chipstrap</string>
    <string name="about_version">Version %1$s (%2$d)</string>
    <string name="about_description">Chipstrap is a native Android (Kotlin + Jetpack Compose) Roblox launcher, forked from the abandoned Chevstrap project. It restores FFlag management disabled by Roblox and adds BloxStrap-inspired server info, activity tracking and a battery of pre-tuned optimization presets.</string>
    <string name="about_inspired_by">Inspired by BloxStrap (Windows) and Chevstrap (Android, discontinued).</string>
    <string name="about_github">GitHub repository</string>
    <string name="about_disclaimer_title">Disclaimer</string>
    <string name="about_disclaimer">Chipstrap is not affiliated with Roblox Corporation. Use at your own risk. Modifying the Roblox client may violate Roblox\'s Terms of Service.</string>
    <string name="about_license">MIT License</string>

