    <!-- Strategies -->
    <string name="strategy_shizuku">Shizuku (recommended)</string>
    <string name="strategy_shizuku_desc">Uses Shizuku to write ClientAppSettings.json into Roblox\'s private data dir. No root needed, survives Roblox updates.</string>
    <string name="strategy_root">Root</string>
    <string name="strategy_root_desc">Uses root to write directly to /data/data/com.roblox.client. Most reliable but requires a rooted device.</string>
    <string name="strategy_virtual">Virtual space</string>
    <string name="strategy_virtual_desc">Runs Roblox inside a parallel-space container that exposes its data dir to Chipstrap.</string>
    <string name="strategy_local">Local profile (no-inject)</string>
    <string name="strategy_local_desc">Cannot inject FFlags into the official Roblox app. Chipstrap will keep a local profile that can be exported/imported, and will only apply prefs that Roblox still honors (e.g. preferred app, haptics).</string>

